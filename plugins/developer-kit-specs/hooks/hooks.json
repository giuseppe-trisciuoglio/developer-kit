{
  "description": "Developer Kit Specs hooks: Task lifecycle automation (auto-status, frontmatter validation)",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "pattern": "TASK-\\d+\\.md$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/task-auto-status.py",
            "statusMessage": "Auto-updating task status..."
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/task-validator.py",
            "statusMessage": "Validating task frontmatter..."
          }
        ]
      }
    ]
  }
}
