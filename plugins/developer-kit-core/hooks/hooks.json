{
  "description": "Core hooks: prevent destructive commands and auto-learn on session stop",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/prevent-destructive-commands.py",
            "statusMessage": "Checking command safety..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/auto-learn-on-stop.py",
            "statusMessage": "Checking if session learning is needed..."
          }
        ]
      }
    ]
  }
}
